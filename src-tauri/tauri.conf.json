{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Samuel",
  "version": "0.1.0",
  "identifier": "com.samuel.bookreader",
  "build": {
    "frontendDist": "../dist-ui",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run ui:dev",
    "beforeBuildCommand": "npm run ui:build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Samuel",
        "width": 360,
        "height": 480,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
